# .env.example

# API runtime
NODE_ENV=development
PORT=3000
JWT_SECRET=replace_with_dev_secret

# Mongo root credentials used by the db container
MONGO_INITDB_ROOT_USERNAME=devuser
MONGO_INITDB_ROOT_PASSWORD=devpassword

# API connection string (works inside Docker Compose network)
MONGO_URI=mongodb://devuser:devpassword@db:27017/beathub_dev?authSource=admin
