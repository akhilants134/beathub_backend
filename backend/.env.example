# Example environment variables for BeatHub backend
# Copy to .env and fill with real secrets (do NOT commit .env)

NODE_ENV=development
PORT=3000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.ngeefqo.mongodb.net/beathub_dev?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d
FRONTEND_URLS=http://localhost:3000
PUBLIC_API_URL=http://localhost:3000
MONGO_INITDB_ROOT_USERNAME=beathub_dev_user
MONGO_INITDB_ROOT_PASSWORD=beathub_dev_password
